{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "functions": {
        "dist/app.js": {
            "maxDuration": 30
        },
        "api/**/*": {
            "memory": 1024
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "dist/app.js"
        }
    ]
}
